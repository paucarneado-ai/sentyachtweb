node_modules/
.git/
.gitignore
.claude/
.playwright-mcp/
claudedocs/
temporary screenshots/
memory/

# Dev-only scripts (not needed in image)
serve.mjs
build.mjs
scripts/

# Build output (Tailwind CSS regenerated in Docker build stage)
dist/

# Documentation (not needed in image)
CLAUDE.md
README.md
DEPLOYMENT.md

